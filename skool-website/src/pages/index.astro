    const root = document.querySelector(".hero");
    if (root) {
      const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      const setMotionState = (e) => { root.dataset.motion = e.matches ? "reduced" : "full"; };
      setMotionState(motionQuery);
      motionQuery.addEventListener("change", setMotionState);
